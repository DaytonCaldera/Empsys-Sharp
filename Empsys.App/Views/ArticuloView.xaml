<Page
    x:Class="Empsys.App.Views.ArticuloView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:Empsys.App.ViewModels"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <StackPanel Padding="40" Spacing="20" MaxWidth="500" HorizontalAlignment="Left">
        <TextBlock Text="Incluir Nuevo Artículo" Style="{ThemeResource TitleTextBlockStyle}" />
        <TextBlock Text="Módulo de Inventario / Empeños" Foreground="Gray" Margin="0,-15,0,10"/>

        <ComboBox Header="Seleccione Familia" 
                  ItemsSource="{x:Bind ViewModel.Familias, Mode=OneWay}"
                  DisplayMemberPath="Descripcion"
                  SelectedValuePath="Id"
                  SelectedValue="{x:Bind ViewModel.SelectedFamiliaId, Mode=TwoWay}"
                  HorizontalAlignment="Stretch"/>

        <ComboBox Header="Seleccione Categoría" 
                  ItemsSource="{x:Bind ViewModel.Categorias, Mode=OneWay}"
                  DisplayMemberPath="Descripcion"
                  SelectedValuePath="Id"
                  SelectedValue="{x:Bind ViewModel.SelectedCategoriaId, Mode=TwoWay}"
                  HorizontalAlignment="Stretch"
                  IsEnabled="{x:Bind ViewModel.HasCategories, Mode=OneWay}"/>

        <TextBox Header="Descripción del Artículo" 
                 Text="{x:Bind ViewModel.Descripcion, Mode=TwoWay}" 
                 PlaceholderText="Ej. Reloj Rolex Submariner Plata"/>

        <TextBox Header="Precio Estimado (Valor de Empeño)" 
                 Text="{x:Bind ViewModel.PrecioEstimadoTexto, Mode=TwoWay}" 
                 PlaceholderText="0.00"/>

        <Button Content="Registrar Artículo en Inventario" 
                Command="{x:Bind ViewModel.GuardarArticuloCommand}" 
                Style="{ThemeResource AccentButtonStyle}"
                HorizontalAlignment="Stretch"/>

        <TextBlock Text="{x:Bind ViewModel.Mensaje, Mode=OneWay}" 
                   Foreground="SteelBlue" 
                   TextWrapping="Wrap"
                   FontWeight="SemiBold"/>
    </StackPanel>
</Page>
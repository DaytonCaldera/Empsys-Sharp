<Page
    x:Class="Empsys.App.Views.CajaView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Empsys.Core.Models"
    Background="White"
    RequestedTheme="Light">

    <ScrollViewer>
        <StackPanel Padding="30" Spacing="20">

            <Border Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20">
                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="20">
                    <StackPanel Grid.Column="0" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="Caja y Operaciones" FontWeight="Bold" FontSize="20" Foreground="#111827" />
                        <TextBlock Text="{x:Bind ViewModel.Mensaje, Mode=OneWay}" Foreground="{StaticResource EmpsysPrimaryBrush}" FontSize="12"/>
                    </StackPanel>

                    <Grid Grid.Column="1" ColumnDefinitions="Auto, *" ColumnSpacing="10" VerticalAlignment="Center" MaxWidth="500" HorizontalAlignment="Left">
                        <TextBox Header="N° Contrato" Text="{x:Bind ViewModel.NumeroContratoBusqueda, Mode=TwoWay}" Grid.Column="0" Width="150"/>
                        <Button Content="Buscar" Command="{x:Bind ViewModel.BuscarContratoCommand}" Grid.Column="1" VerticalAlignment="Bottom" Style="{StaticResource EmpsysBotonPrincipal}"/>
                    </Grid>

                    <StackPanel Grid.Column="2" Spacing="5" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Cliente:" Foreground="#6B7280" FontSize="12"/>
                        <TextBlock Text="{x:Bind ViewModel.NombreCliente, Mode=OneWay}" Foreground="#111827" FontWeight="Bold" FontSize="16"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="1*, 1.2*" ColumnSpacing="20">

                <Grid Grid.Column="0" RowDefinitions="Auto, *" RowSpacing="15">

                    <Border Grid.Row="0" Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Padding="15">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Resumen de Garantía" FontWeight="SemiBold" Foreground="#1F2937"/>
                            <TextBlock Text="Prendas:" Foreground="#6B7280" FontSize="12"/>
                            <TextBlock Text="{x:Bind ViewModel.DescripcionPrendas, Mode=OneWay}" Foreground="#111827" FontWeight="SemiBold" TextWrapping="Wrap"/>

                            <Grid ColumnDefinitions="*, *">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Tasa Int. Mensual" Foreground="#6B7280" FontSize="12"/>
                                    <TextBlock Text="{x:Bind ViewModel.ContratoActual.TasaInteresMensual, Mode=OneWay, FallbackValue='0'}" Foreground="#111827" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock Text="Vencimiento Actual" Foreground="#6B7280" FontSize="12"/>
                                    <TextBlock Text="{x:Bind ViewModel.FechaVencimientoTexto, Mode=OneWay}" Foreground="#D13438" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Background="#F9FAFB" CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1" Padding="20">
                        <Grid RowDefinitions="Auto, *, Auto" RowSpacing="15">
                            <TextBlock Grid.Row="0" Text="Procesar Pago" FontWeight="Bold" FontSize="16" Foreground="#111827" HorizontalAlignment="Center"/>

                            <StackPanel Grid.Row="1" Spacing="12">
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Grid.Column="0" Text="Capital Pendiente:" Foreground="#4B5563"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.CapitalPendiente, Mode=OneWay}" Foreground="#111827" FontWeight="Bold"/>
                                </Grid>

                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Grid.Column="0" Text="Interés por 1 Mes:" Foreground="#4B5563"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.InteresPorMesOriginal, Mode=OneWay}" Foreground="#111827" FontWeight="SemiBold"/>
                                </Grid>

                                <Line X1="0" X2="1000" Stroke="#E5E7EB" StrokeThickness="1"/>

                                <Grid ColumnDefinitions="*, Auto" VerticalAlignment="Center">
                                    <TextBlock Grid.Column="0" Text="N° Meses a Cobrar (Renovación):" FontWeight="SemiBold" Foreground="#1F2937" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" Width="100" 
                                              ItemsSource="{x:Bind ViewModel.MesesAPagarOpciones}"
                                              SelectedItem="{x:Bind ViewModel.MesesAPagarSeleccionados, Mode=TwoWay}"
                                              IsEnabled="{x:Bind ViewModel.HayContratoActivo, Mode=OneWay}"/>
                                </Grid>

                                <Grid ColumnDefinitions="*, Auto" Background="#EDF2F7" Padding="10" CornerRadius="4">
                                    <TextBlock Grid.Column="0" Text="Total Intereses a Pagar:" FontWeight="SemiBold" Foreground="#1F2937"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.InteresesAcumulados, Mode=OneWay}" Foreground="#D13438" FontWeight="Bold"/>
                                </Grid>

                                <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,0">
                                    <TextBlock Grid.Column="0" Text="Total para Cancelar (Desempeño):" Foreground="#4B5563"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.TotalDesempeno, Mode=OneWay}" Foreground="#6B7280"/>
                                </Grid>
                            </StackPanel>

                            <Grid Grid.Row="2" ColumnDefinitions="1.2*, 1*" ColumnSpacing="15">
                                <Button Grid.Column="0" HorizontalAlignment="Stretch" Height="50" Style="{StaticResource EmpsysBotonPrincipal}"
                                        Command="{x:Bind ViewModel.ProcesarRenovacionCommand}"
                                        IsEnabled="{x:Bind ViewModel.HayContratoActivo, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE8B9;" FontSize="16"/>
                                        <TextBlock Text="Pagar Intereses (Renovar)" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>

                                <Button Grid.Column="1" HorizontalAlignment="Stretch" Height="50" 
                                        Background="{StaticResource EmpsysSuccessBrush}" Foreground="White" CornerRadius="6"
                                        Command="{x:Bind ViewModel.ProcesarDesempenoCommand}"
                                        IsEnabled="{x:Bind ViewModel.HayContratoActivo, Mode=OneWay}">
                                    <TextBlock Text="Cancelar Contrato" FontWeight="SemiBold"/>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20">
                    <Grid RowDefinitions="Auto, *">
                        <TextBlock Grid.Row="0" Text="Historial de Renovaciones / Pagos" FontWeight="SemiBold" FontSize="16" Foreground="#1F2937" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.HistorialPagos}" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="4" Background="#F9FAFB">
                            <ListView.Header>
                                <Grid Padding="10" Background="#E5E7EB" ColumnDefinitions="Auto, Auto, Auto, Auto">
                                    <TextBlock Grid.Column="0" Text="Fecha Pago" FontWeight="SemiBold" Foreground="#374151"/>
                                    <TextBlock Grid.Column="1" Text="Tipo" FontWeight="SemiBold" Foreground="#374151" Width="80" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Meses" FontWeight="SemiBold" Foreground="#374151" Width="60" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="Nuev. Venc" FontWeight="SemiBold" Foreground="#374151" HorizontalAlignment="Right"/>
                                </Grid>
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Pago">
                                    <Grid Padding="10" ColumnDefinitions="*, Auto, Auto, *">
                                        <TextBlock Grid.Column="0" Text="{x:Bind FechaPago}" Foreground="#111827"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Tipo}" Foreground="#111827" Width="80" HorizontalAlignment="Center"/>

                                        <TextBlock Grid.Column="2" Text="{x:Bind MesesPagados}" Foreground="#111827" Width="60" HorizontalAlignment="Center" FontWeight="SemiBold"/>

                                        <TextBlock Grid.Column="3" Text="{x:Bind NuevaFechaVencimiento}" Foreground="#D13438" HorizontalAlignment="Right" FontWeight="Bold"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
<Page
    x:Class="Empsys.App.Views.ContratoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Empsys.Core.Models"
    Background="White"
    RequestedTheme="Light">
    <ScrollViewer>
        <StackPanel Padding="40" Spacing="20">

            <!-- TÍTULO -->
            <StackPanel Spacing="5" Margin="0,0,0,10">
                <TextBlock Text="Creación de Contrato de Empeño" 
                           Style="{ThemeResource TitleTextBlockStyle}" 
                           Foreground="#111827" />
                <TextBlock Text="Módulo de Ingreso a Inventario y Emisión" 
                           Foreground="#6B7280" FontSize="14"/>
            </StackPanel>

            <!-- SECCIÓN 1: CLIENTE -->
            <Border Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Padding="24">
                <StackPanel Spacing="12">
                    <TextBlock Text="1. Información del Cliente" 
                               FontWeight="SemiBold" FontSize="16" Foreground="#1F2937"/>

                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="15" MaxWidth="500" HorizontalAlignment="Left">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Cédula" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                            <TextBox Text="{x:Bind ViewModel.CedulaBusqueda, Mode=TwoWay}"
                                     Width="300"
                                     PlaceholderText="Ej. 1-1234-5678"
                                     Foreground="#111827"
                                     Background="White"
                                     BorderBrush="#D1D5DB"
                                     TabIndex="0">
                                <TextBox.KeyboardAccelerators>
                                    <KeyboardAccelerator Modifiers="None" Key="Enter" 
                                                         Invoked="CedulaEnter_Invoked"/>
                                </TextBox.KeyboardAccelerators>
                            </TextBox>
                        </StackPanel>
                        <Button Content="Buscar" 
                                Command="{x:Bind ViewModel.BuscarClienteCommand}" 
                                Grid.Column="1" 
                                VerticalAlignment="Bottom"
                                TabIndex="1"
                                Style="{StaticResource EmpsysBotonPrincipal}"/>
                    </Grid>

                    <TextBlock Text="{x:Bind ViewModel.NombreCliente, Mode=OneWay}" 
                               Foreground="{StaticResource EmpsysPrimaryBrush}" 
                               FontWeight="Bold" FontSize="15" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- SECCIÓN 2: ARTÍCULOS -->
            <Border Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="2. Valoración e Inclusión a Inventario" 
                               FontWeight="SemiBold" FontSize="16" Foreground="#1F2937"/>

                    <Grid ColumnDefinitions="1.2*, 1.2*, 2*, 1*, Auto" ColumnSpacing="16">

                        <!-- Familia -->
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Familia" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                            <ComboBox HorizontalAlignment="Stretch"
                                      ItemsSource="{x:Bind ViewModel.Familias}"
                                      DisplayMemberPath="Descripcion"
                                      SelectedValuePath="Id"
                                      SelectedValue="{x:Bind ViewModel.SelectedFamiliaId, Mode=TwoWay}"
                                      Foreground="#111827"
                                      Background="White"
                                      BorderBrush="#D1D5DB"
                                      TabIndex="2"/>
                        </StackPanel>

                        <!-- Categoría -->
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Categoría" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                            <ComboBox HorizontalAlignment="Stretch"
                                      ItemsSource="{x:Bind ViewModel.Categorias, Mode=OneWay}"
                                      DisplayMemberPath="Descripcion"
                                      SelectedValuePath="Id"
                                      SelectedValue="{x:Bind ViewModel.SelectedCategoriaId, Mode=TwoWay}"
                                      IsEnabled="{x:Bind ViewModel.HasCategorias, Mode=OneWay}"
                                      Foreground="#111827"
                                      Background="White"
                                      BorderBrush="#D1D5DB"
                                      TabIndex="3"/>
                        </StackPanel>

                        <!-- Artículo -->
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="Artículo del Catálogo" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                            <ComboBox HorizontalAlignment="Stretch"
                                      ItemsSource="{x:Bind ViewModel.ArticulosCatalogo, Mode=OneWay}"
                                      DisplayMemberPath="Descripcion"
                                      SelectedValuePath="Id"
                                      SelectedValue="{x:Bind ViewModel.SelectedArticuloId, Mode=TwoWay}"
                                      IsEnabled="{x:Bind ViewModel.HasArticulos, Mode=OneWay}"
                                      Foreground="#111827"
                                      Background="White"
                                      BorderBrush="#D1D5DB"
                                      TabIndex="4"/>
                        </StackPanel>

                        <!-- Valor -->
                        <StackPanel Grid.Column="3" Spacing="4">
                            <TextBlock Text="Valor a Prestar ($)" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                            <TextBox Text="{x:Bind ViewModel.ValorArticuloTexto, Mode=TwoWay}"
                                     PlaceholderText="0.00"
                                     Foreground="#111827"
                                     Background="White"
                                     BorderBrush="#D1D5DB"
                                     TabIndex="5">
                                <TextBox.KeyboardAccelerators>
                                    <KeyboardAccelerator Modifiers="None" Key="Enter"
                                                         Invoked="ValorEnter_Invoked"/>
                                </TextBox.KeyboardAccelerators>
                            </TextBox>
                        </StackPanel>

                        <Button Grid.Column="4" Content="Incluir"
                                Command="{x:Bind ViewModel.AgregarArticuloAlGridCommand}"
                                Style="{StaticResource EmpsysBotonPrincipal}"
                                VerticalAlignment="Bottom"
                                TabIndex="6"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- SECCIÓN 3 y 4: GRID + NOTAS -->
            <Grid ColumnDefinitions="3*, 2*" ColumnSpacing="20" Height="300">

                <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20">
                    <Grid RowDefinitions="Auto, *, Auto">
                        <TextBlock Grid.Row="0" Text="3. Detalle de Garantías" 
                                   FontWeight="SemiBold" FontSize="16" Foreground="#1F2937" Margin="0,0,0,12"/>

                        <ListView Grid.Row="1"
                                  ItemsSource="{x:Bind ViewModel.ArticulosEnGrid}"
                                  SelectedItem="{x:Bind ViewModel.ArticuloSeleccionadoEnGrid, Mode=TwoWay}"
                                  BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6"
                                  Background="#F9FAFB"
                                  TabIndex="7">
                            <ListView.Header>
                                <Grid Padding="15" Background="#E5E7EB" ColumnDefinitions="3*, 1*">
                                    <TextBlock Grid.Column="0" Text="Descripción del Artículo" 
                                               FontWeight="SemiBold" Foreground="#374151"/>
                                    <TextBlock Grid.Column="1" Text="Valor Asignado" 
                                               FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="#374151"/>
                                </Grid>
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Inventario">
                                    <Grid Padding="15,12" ColumnDefinitions="3*, 1*">
                                        <TextBlock Grid.Column="0" Text="{x:Bind Articulo.Descripcion}" 
                                                   Foreground="#111827" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind PrecioEstimado}" 
                                                   Foreground="#111827" HorizontalAlignment="Right" 
                                                   FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <!-- Delete key para quitar artículo seleccionado -->
                            <ListView.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="None" Key="Delete"
                                                     Invoked="ListaDelete_Invoked"/>
                            </ListView.KeyboardAccelerators>
                        </ListView>

                        <Button Grid.Row="2" Margin="0,12,0,0"
                                Command="{x:Bind ViewModel.QuitarArticuloDelGridCommand}"
                                Background="Transparent"
                                BorderBrush="{StaticResource EmpsysDangerBrush}"
                                BorderThickness="1"
                                Foreground="{StaticResource EmpsysDangerBrush}"
                                CornerRadius="4"
                                TabIndex="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                <TextBlock Text="Excluir Garantía Seleccionada" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20">
                    <Grid RowDefinitions="Auto, *">
                        <TextBlock Grid.Row="0" Text="4. Términos Adicionales y Notas" 
                                   FontWeight="SemiBold" FontSize="16" Foreground="#1F2937" Margin="0,0,0,12"/>
                        <TextBox Grid.Row="1"
                                 Text="{x:Bind ViewModel.DescripcionContrato, Mode=TwoWay}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalAlignment="Stretch"
                                 HorizontalAlignment="Stretch"
                                 Foreground="#111827"
                                 Background="White"
                                 BorderBrush="#D1D5DB"
                                 PlaceholderText="Escriba condiciones de entrega, desgaste de las prendas u observaciones especiales para la bóveda..."
                                 TabIndex="9"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- SECCIÓN 5: TOTAL Y CONFIRMAR -->
            <Border Background="#EBF5FF" CornerRadius="8" BorderBrush="#BFDBFE" BorderThickness="1" Padding="24" Margin="0,10,0,0">
                <Grid ColumnDefinitions="Auto, Auto, *, Auto" ColumnSpacing="40">

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="TOTAL A DESEMBOLSAR" FontSize="12" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="$" FontSize="26" FontWeight="Bold" 
                                       Foreground="{StaticResource EmpsysSuccessBrush}" 
                                       VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalPrestamo, Mode=OneWay}" 
                                       FontSize="34" FontWeight="Bold" 
                                       Foreground="{StaticResource EmpsysSuccessBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="Tasa de Interés (%)" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                        <TextBox Text="{x:Bind ViewModel.TasaInteresTexto, Mode=TwoWay}"
                                 Width="140"
                                 Foreground="#111827"
                                 Background="White"
                                 BorderBrush="#D1D5DB"
                                 TabIndex="10"/>
                    </StackPanel>

                    <Button Grid.Column="3"
                            Content="💾 Confirmar y Generar Contrato"
                            Command="{x:Bind ViewModel.EmitirContratoCommand}"
                            Background="{StaticResource EmpsysSuccessBrush}"
                            Foreground="White" CornerRadius="6" Height="55"
                            FontSize="16" FontWeight="Bold" MinWidth="260"
                            VerticalAlignment="Center"
                            TabIndex="11">
                        <Button.KeyboardAccelerators>
                            <KeyboardAccelerator Modifiers="Control" Key="Enter"/>
                        </Button.KeyboardAccelerators>
                    </Button>
                </Grid>
            </Border>

            <TextBlock Text="{x:Bind ViewModel.Mensaje, Mode=OneWay}" 
                       Foreground="{StaticResource EmpsysPrimaryBrush}" 
                       FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center"/>

        </StackPanel>
    </ScrollViewer>
</Page>
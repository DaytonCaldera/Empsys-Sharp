<Page
    x:Class="Empsys.App.Views.CategoriaView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:Empsys.App.ViewModels"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <StackPanel Padding="40" Spacing="20" MaxWidth="500" HorizontalAlignment="Left">
        <TextBlock Text="Incluir Categoría de Artículos" Style="{ThemeResource TitleTextBlockStyle}" />
        <TextBlock Text="Módulo de Inventario" Foreground="Gray" Margin="0,-15,0,10"/>

        <ComboBox Header="Familia Asociada" 
                  ItemsSource="{x:Bind ViewModel.Familias, Mode=OneWay}"
                  DisplayMemberPath="Descripcion"
                  SelectedValuePath="Id"
                  SelectedValue="{x:Bind ViewModel.SelectedFamiliaId, Mode=TwoWay}"
                  HorizontalAlignment="Stretch"/>

        <TextBox Header="Nombre de la Categoría" 
                 Text="{x:Bind ViewModel.Descripcion, Mode=TwoWay}" 
                 PlaceholderText="Ej. Anillos de Oro, Relojes, Cadenas"/>

        <Button Content="Guardar Categoría" 
                Command="{x:Bind ViewModel.GuardarCategoriaCommand}" 
                Style="{ThemeResource AccentButtonStyle}"
                HorizontalAlignment="Stretch"/>

        <TextBlock Text="{x:Bind ViewModel.Mensaje, Mode=OneWay}" 
                   Foreground="SteelBlue" 
                   TextWrapping="Wrap"
                   FontWeight="SemiBold"/>
    </StackPanel>
</Page>
<Page
    x:Class="Empsys.App.Views.FamiliaView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:Empsys.App.ViewModels"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <StackPanel Padding="40" Spacing="20" MaxWidth="500" HorizontalAlignment="Left">

        <TextBlock Text="Incluir Familia de Artículos" Style="{ThemeResource TitleTextBlockStyle}" />
        <TextBlock Text="Módulo de Inventario" Foreground="Gray" Margin="0,-15,0,10"/>

        <TextBox Header="Código de Familia" 
                 Text="{x:Bind ViewModel.Codigo, Mode=TwoWay}" 
                 PlaceholderText="Ej. JOY"/>

        <TextBox Header="Descripción de la Familia" 
                 Text="{x:Bind ViewModel.Descripcion, Mode=TwoWay}" 
                 PlaceholderText="Ej. Joyería de Oro"/>

        <Button Content="Guardar Registro" 
                Command="{x:Bind ViewModel.GuardarFamiliaCommand}" 
                Style="{ThemeResource AccentButtonStyle}"
                HorizontalAlignment="Stretch"/>

        <TextBlock Text="{x:Bind ViewModel.Mensaje, Mode=OneWay}" 
                   Foreground="SteelBlue" 
                   TextWrapping="Wrap"
                   FontWeight="SemiBold"/>

    </StackPanel>
</Page>
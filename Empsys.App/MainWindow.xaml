<Window
    x:Class="Empsys.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Empsys.App.Views"
    Title="EMPSYS - Sistema de Empeños Moderno">

    <Grid>

        <NavigationView x:Name="NavPrincipal"
                        Visibility="Collapsed" 
                        Header="Consola de Administración"
                        PaneDisplayMode="Left"
                        SelectionChanged="NavPrincipal_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Clientes" Tag="ClientesPage" Icon="People" />
                <NavigationViewItemSeparator/>
                <NavigationViewItemHeader Content="Empeños"/>
                <NavigationViewItem Content="Contratos" Tag="ContratosPage" Icon="Document" />
                <NavigationViewItem Content="Renovaciones" Tag="RenovacionesPage" Icon="Calculator" />
                <NavigationViewItemSeparator/>
                <NavigationViewItemHeader Content="Inventario"/>
                <NavigationViewItem Content="Familias" Tag="FamiliasPage" Icon="Folder" />
                <NavigationViewItem Content="Categorías" Tag="CategoriasPage" Icon="Tag" />
                <NavigationViewItem Content="Artículos" Tag="ArticulosPage" Icon="Document" />
            </NavigationView.MenuItems>

            <Frame x:Name="ContenedorPrincipal" Margin="12"/>
        </NavigationView>

        <Grid x:Name="CapaLogin" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20" Width="300">

                <TextBlock Text="🔒 EMPSYS" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Ingreso al Sistema" Foreground="Gray" HorizontalAlignment="Center" Margin="0,-10,0,20"/>

                <TextBox Header="Usuario" 
                         Text="{x:Bind LoginViewModel.Username, Mode=TwoWay}" />

                <PasswordBox Header="Contraseña" 
                             Password="{x:Bind LoginViewModel.Password, Mode=TwoWay}" />

                <Button Content="Iniciar Sesión" 
                        Command="{x:Bind LoginViewModel.IngresarCommand}" 
                        Style="{ThemeResource AccentButtonStyle}"
                        HorizontalAlignment="Stretch" Margin="0,10,0,0"/>

                <TextBlock Text="{x:Bind LoginViewModel.MensajeError, Mode=OneWay}" 
                           Foreground="IndianRed" 
                           HorizontalAlignment="Center" 
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
<Application
    x:Class="Empsys.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="EmpsysPrimaryBrush" Color="#005A9E" />
            <SolidColorBrush x:Key="EmpsysSuccessBrush" Color="#107C10" />
            <SolidColorBrush x:Key="EmpsysDangerBrush" Color="#D13438" />
            <SolidColorBrush x:Key="EmpsysBackgroundBrush" Color="#2B2B2B"/>
            <Style TargetType="TextBox">
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="MinHeight" Value="35" />
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="MinHeight" Value="35" />
                <Setter Property="Background" Value="{StaticResource EmpsysBackgroundBrush}" />
                <Setter Property="Foreground" Value="White" />
            </Style>

            <Style x:Key="EmpsysBotonPrincipal" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource EmpsysPrimaryBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="20,10" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>